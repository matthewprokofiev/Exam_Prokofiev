<Window x:Class="Exam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Демонстрационный экзамен — подсчёт баллов"
        Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Подсчёт баллов демонстрационного экзамена"
                   FontSize="16" FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="Уровень экзамена" Padding="8" Margin="0,0,0,15">
            <StackPanel>

                <RadioButton x:Name="rbBU"
                             Content="Базовый (БУ) — модули 1–3"
                             IsChecked="True"
                             Checked="Level_Changed"
                             Margin="0,3"/>

                <RadioButton x:Name="rbPU"
                             Content="Профильный (ПУ) — модули 1–4"
                             Checked="Level_Changed"
                             Margin="0,3"/>

                <RadioButton x:Name="rbPUPlus"
                             Content="Профильный с вариативной частью (ПУ+) — модули 1–5"
                             Checked="Level_Changed"
                             Margin="0,3"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Баллы по модулям" Padding="8" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Модуль 1 (макс. 10):"
                           VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="tbM1" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Модуль 2 (макс. 15):"
                           VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="tbM2" Margin="0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Модуль 3 (макс. 25):"
                           VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="tbM3" Margin="0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Модуль 4 (макс. 25):"
                           VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="tbM4" Margin="0,4"
                         IsEnabled="False"/>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="Модуль 5, вариативная часть (макс. 25):"
                           VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="tbM5" Margin="0,4"
                         IsEnabled="False"/>
            </Grid>
        </GroupBox>

        <Button Grid.Row="3" x:Name="buttonCalculate"
                Content="Рассчитать"
                Height="34" FontSize="14"
                Click="buttonCalculate_Click"
                Margin="0,0,0,15"/>

        <GroupBox Grid.Row="4" Header="Результат" Padding="8">
            <TextBlock x:Name="tbResult"
                       FontSize="14"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"/>
        </GroupBox>
    </Grid>
</Window>
